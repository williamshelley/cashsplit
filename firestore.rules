rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /groups/{groupId} {
      // A signed-in user with a verified email address.
      function verified() {
        return request.auth != null
          && request.auth.token.email_verified == true;
      }

      // A verified user who is already a member of this group.
      function isMember() {
        return verified()
          && request.auth.uid in resource.data.memberUids;
      }

      // A verified non-member self-joining: the ONLY change to memberUids is
      // the addition of their own uid (they cannot add anyone else).
      function isJoining() {
        return verified()
          && !(request.auth.uid in resource.data.memberUids)
          && request.resource.data.memberUids.toSet()
               .difference(resource.data.memberUids.toSet()) == [request.auth.uid].toSet();
      }

      allow read: if isMember();

      allow create: if verified()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow update: if isMember() || isJoining();

      allow delete: if isMember()
        && resource.data.ownerUid == request.auth.uid;
    }

    // Everything else is denied by default.
  }
}
