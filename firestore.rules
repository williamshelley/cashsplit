rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /groups/{groupId} {
      // A signed-in user with a verified email address.
      function verified() {
        return request.auth != null
          && request.auth.token.email_verified == true;
      }

      // A verified user who is already a member of this group.
      function isMember() {
        return verified()
          && request.auth.uid in resource.data.memberUids;
      }

      // Fields that no client write may ever change on an existing group.
      function immutableFieldsUnchanged() {
        return request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      // A member editing group content (name / people / expenses / settlements).
      // Membership is never altered by a member edit, so it cannot be used to
      // seize ownership or evict other members.
      function isMemberEdit() {
        return isMember()
          && immutableFieldsUnchanged()
          && request.resource.data.memberUids == resource.data.memberUids;
      }

      // A verified non-member self-joining: the ONLY change is adding their own
      // uid to memberUids. No existing member may be removed, and no other field
      // (owner, name, people, expenses, settlements, createdAt) may be touched.
      function isJoining() {
        return verified()
          && !(request.auth.uid in resource.data.memberUids)
          && immutableFieldsUnchanged()
          && request.resource.data.name == resource.data.name
          && request.resource.data.people == resource.data.people
          && request.resource.data.expenses == resource.data.expenses
          && request.resource.data.settlements == resource.data.settlements
          && request.resource.data.memberUids.toSet()
               .difference(resource.data.memberUids.toSet()) == [request.auth.uid].toSet()
          && resource.data.memberUids.toSet()
               .difference(request.resource.data.memberUids.toSet()).size() == 0;
      }

      allow read: if isMember();

      allow create: if verified()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow update: if isMemberEdit() || isJoining();

      allow delete: if isMember()
        && resource.data.ownerUid == request.auth.uid;
    }

    // Everything else is denied by default.
  }
}
